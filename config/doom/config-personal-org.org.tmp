****** Backlog triage
Helper functions and keybindings to quickly assign tasks in the agenda to specific weeks.

- `w .` :: Assign entry at point to the current week (`cashpw/org-agenda-assign-to-this-week`)
- `w n` :: Assign entry at point to the next week (`cashpw/org-agenda-assign-to-next-week`)
- `w w` :: Assign entry at point to a custom week (`cashpw/org-agenda-assign-to-week`)

#+begin_src emacs-lisp :tangle config-personal.el :results none
(defun cashpw/org-agenda-update-week-tags (current-tags week-tag)
  "Return CURRENT-TAGS with old week tags removed and WEEK-TAG added if non-nil/non-empty.
WEEK-TAG must match YYYYwWW format if provided."
  (when (and week-tag (not (string-empty-p week-tag))
             (not (string-match-p "^[0-9]\\{4\\}w[0-9]\\{2\\}$" week-tag)))
    (user-error "Invalid week tag format: %s. Expected YYYYwWW" week-tag))
  ;; Remove any existing week tags matching YYYYwWW format (e.g., 2026w21)
  (let ((clean-tags (--remove (string-match-p "^[0-9]\\{4\\}w[0-9]\\{2\\}$" it) current-tags)))
    (if (and week-tag (not (string-empty-p week-tag)))
        (append clean-tags (list week-tag))
      clean-tags)))

(defun cashpw/org-agenda-assign-to-week (week-tag)
  "Assign the entry at point to the specified WEEK-TAG, cleaning out old week tags."
  (interactive (list (read-string "Week (YYYYwWW): " (cashpw-time-current-week-tag))))
  (let* ((marker (or (get-text-property (point) 'org-marker)
                     (user-error "No entry at point")))
         (buffer (marker-buffer marker))
         (pos (marker-position marker)))
    (unless (and buffer (buffer-live-p buffer))
      (user-error "Marker points to an invalid or killed buffer"))
    (with-current-buffer buffer
      (save-excursion
        (goto-char pos)
        (org-set-tags (cashpw/org-agenda-update-week-tags (org-get-tags nil 'local) week-tag))
        (org-todo-trigger-tag-changes nil)))
    (org-agenda-redo)))

(defun cashpw/org-agenda-assign-to-this-week ()
  "Assign entry at point to this week."
  (interactive)
  (cashpw/org-agenda-assign-to-week (cashpw-time-current-week-tag)))

(defun cashpw/org-agenda-assign-to-next-week ()
  "Assign entry at point to next week."
  (interactive)
  (cashpw/org-agenda-assign-to-week (cashpw-time-next-week-tag)))

(after! evil-org-agenda
  (map! :map evil-org-agenda-mode-map
        :m "w" nil ;; Unbind word motion in agenda
        (:prefix ("w" . "Assign to week")
         :m "." #'cashpw/org-agenda-assign-to-this-week
         :m "n" #'cashpw/org-agenda-assign-to-next-week
         :m "w" #'cashpw/org-agenda-assign-to-week)))

(defun cashpw/org-agenda-bulk-assign-to-week (week-tag)
  "Bulk assign marked entries to WEEK-TAG."
  (org-agenda-with-point-at-orig-entry nil
    (org-set-tags (cashpw/org-agenda-update-week-tags (org-get-tags nil 'local) week-tag))
    (org-todo-trigger-tag-changes nil)))

(defun cashpw/org-agenda-bulk-assign-to-week-arg ()
  "Prompt for week assignment arguments during bulk action."
  (let* ((key (read-char-choice "Assign marked to week: [.] This week, [n] Next week, [w] Custom week" '(?\. ?n ?w)))
         (week-tag (cond
                    ((= key ?\.) (cashpw-time-current-week-tag))
                    ((= key ?n) (cashpw-time-next-week-tag))
                    ((= key ?w) (read-string "Week (YYYYwWW): " (cashpw-time-current-week-tag))))))
    (list week-tag)))
#+end_src

#+begin_src emacs-lisp :tangle tests.el
(ert-deftest cashpw/org-agenda-update-week-tags-test ()
  "Test tag updates using cashpw/org-agenda-update-week-tags."
  ;; 1. Add a new week tag (replaces existing week tag)
  (should (equal (cashpw/org-agenda-update-week-tags '("work" "2026w21") "2026w22")
                 '("work" "2026w22")))
  ;; 2. Empty week tag removes existing week tag
  (should (equal (cashpw/org-agenda-update-week-tags '("work" "2026w21") "")
                 '("work")))
  ;; 3. Nil week tag removes existing week tag
  (should (equal (cashpw/org-agenda-update-week-tags '("work" "2026w21") nil)
                 '("work")))
  ;; 4. Invalid week tag signals a user-error
  (should-error (cashpw/org-agenda-update-week-tags '("work") "invalid-week")
                :type 'user-error))

