    (cashpw/org-agenda-custom-commands--update)))

(defvar cashpw-org-agenda-next-week-tag nil
  "Dynamic variable to cache next week's tag during agenda generation.")

(defun cashpw/org-agenda-custom-commands-wrap (orig-fn &rest args)
  "Update custom commands and bind next-week tag dynamically."
