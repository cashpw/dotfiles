(defun cashpw/org-mode-buffer-property-get (property-name)
  "Return the value of buffer-level Org-mode property PROPERTY-NAME."
  (org-with-point-at 1
    (when (re-search-forward
           (concat "^#\\+" property-name ": \\(.*\\)")
           (point-max) t)
      (buffer-substring-no-properties
       (match-beginning 1)
       (match-end 1)))))
