****** =cashpw/org-reschedule-to-today-at-point=

#+begin_src emacs-lisp :tangle config-personal.el :results none
(defun cashpw/org-reschedule-to-today-at-point ()
  "Reschedule heading at point to today. Keep time, duration, and repeater."
  (interactive)
  (when-let ((scheduled-time-string (org-entry-get (point) "SCHEDULED")))
    (let ((new-time-string
           (replace-regexp-in-string
            "[0-9]\\{4\\}-[0-9]\\{2\\}-[0-9]\\{2\\}\\(?: [A-Za-z]+\\)?"
            (format-time-string "%Y-%m-%d %a")
            scheduled-time-string)))
      (org-schedule nil new-time-string))))

(defun cashpw/org-agenda-reschedule-to-today ()
  "Reschedule event at point to today."
  (interactive)
  (org-agenda-with-point-at-orig-entry
      nil (cashpw/org-reschedule-to-today-at-point)))
#+end_src

#+begin_src emacs-lisp
(ert-deftest cashpw/org-reschedule-to-today-at-point-test ()
  "Test rescheduling an Org heading to today while preserving extra time properties."
  (let ((today-str (format-time-string "%Y-%m-%d %a")))
    
    ;; Case 1: Standard date with day name
    (with-temp-buffer
      (org-mode)
      (insert "* TODO Task 1\nSCHEDULED: <2020-01-01 Wed>\n")
      (goto-char (point-min))
      (cashpw/org-reschedule-to-today-at-point)
      (should (string-match-p (regexp-quote (format "<%s>" today-str))
                              (buffer-string))))

    ;; Case 2: Date, time, duration, and repeater
    (with-temp-buffer
      (org-mode)
      (insert "* TODO Task 2\nSCHEDULED: <2020-01-01 Wed 10:00-12:00 +1w>\n")
      (goto-char (point-min))
      (cashpw/org-reschedule-to-today-at-point)
      (should (string-match-p (regexp-quote (format "<%s 10:00-12:00 +1w>" today-str))
                              (buffer-string))))

    ;; Case 3: Missing day name in the original timestamp
    (with-temp-buffer
      (org-mode)
      (insert "* TODO Task 3\nSCHEDULED: <2020-01-01>\n")
      (goto-char (point-min))
      (cashpw/org-reschedule-to-today-at-point)
      (should (string-match-p (regexp-quote (format "<%s>" today-str))
                              (buffer-string))))

    ;; Case 4: No SCHEDULED property present (graceful exit)
    (with-temp-buffer
      (org-mode)
      (insert "* TODO Task 4\n")
      (goto-char (point-min))
      (cashpw/org-reschedule-to-today-at-point)
      (should (string= "* TODO Task 4\n" (buffer-string))))))
#+end_src
