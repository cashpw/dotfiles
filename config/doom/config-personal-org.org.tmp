(defun cashpw/org-agenda-view--plan--week ()
  "Return the non-daily Week Planner view configuration."
  `((alltodo
     ""
     ((org-agenda-overriding-header "Week Planner & Backlog Board")
      (org-agenda-sorting-strategy '((todo . (priority-down category-keep))))
      (org-super-agenda-groups
       `((:name "This Week"
          :tag ,(cashpw-time-current-week-tag))
         (:name "Next Week"
          :tag ,(cashpw-time-next-week-tag))
         (:name "Future Weeks"
          :pred cashpw/org-agenda-item-future-week-p)
         (:discard
          (:pred cashpw/org-agenda-item-has-week-tag-p
           :scheduled t
           :deadline t
           :tag "everyday"
           :tag "unscheduled"
           :todo "PROJ"))
         (:name "Backlog"
          :auto-map cashpw/org-super-agenda--get-bug-id
          :transformer cashpw/org-super-agenda--simplify-map)
         (:discard (:anything))))))))

