(defun cashpw/org-agenda-view--today ()
  "Return custom agenda command."
  (let ((week-tag (cashpw-time-current-week-tag)))
    `((agenda
               ""
               ((org-agenda-overriding-header "")
      (org-agenda-dim-blocked-tasks t)
      (org-agenda-use-tag-inheritance t)
      (org-use-property-inheritance t)
      (org-agenda-span 1)
      (org-agenda-scheduled-leaders '("" "Sched.%2dx: "))
      (org-agenda-files (cashpw/org-agenda-view--today--files))
      (org-agenda-prefix-format '((agenda . " %i %-21(cashpw/org-agenda-category 20)%-12t%-2(cashpw/org-agenda-icon)%-5e")))
      (org-agenda-cmp-user-defined
       (lambda (a b)
         (when-let* ((a-marker (get-text-property 0 'org-marker a))
                     (b-marker (get-text-property 0 'org-marker b)))
           (if (or
                (when-let ((a-scheduled-time (org-get-scheduled-time a-marker)))
                  (cl-destructuring-bind (_ minute hour _ _ _ _ _ _) (decode-time a-scheduled-time)
                    (or (not (= 0 minute))
                        (not (= 0 hour)))))
                (when-let ((b-scheduled-time (org-get-scheduled-time b-marker)))
                  (cl-destructuring-bind (_ minute hour _ _ _ _ _ _) (decode-time b-scheduled-time)
                    (or (not (= 0 minute))
                        (not (= 0 hour))))))
               ;; Fall back to other sorts
               nil
             ;; Otherwise, sort alphabetically by heading
             (if (string>
                  (org-entry-get a-marker "ITEM")
                  (org-entry-get b-marker "ITEM"))
                 1
               -1)))))
      (org-agenda-sorting-strategy '((agenda . (user-defined-up time-up priority-down category-keep))))
      (org-super-agenda-groups
       '((:discard
          (:deadline past
           :deadline future
           :scheduled future
           :scheduled past))
         (:name "Holiday(s)"
          :tag "holiday")
         (:name "Schedule"
          :time-grid t
          :order 0
          :transformer (--> it
                            (cashpw/org-agenda--simplify-line it)
                            (cashpw/org-agenda--maybe-dim-headline it)))
         (:discard
          (:and (:file-path ,(cashpw/path-calendar)
                 :scheduled past)))
         (:name "In Progress"
          :todo "INPROGRESS")
         (:auto-map cashpw/org-super-agenda--get-priority
          :transformer cashpw/org-super-agenda--simplify-map)
         (;; Toss all other todos
          :discard
          (:anything))))))
      (tags-todo
       ,week-tag
       ((org-agenda-overriding-header ,(format "This Week's Priorities (%s)" week-tag))
        (org-agenda-sorting-strategy '((todo . (priority-down category-keep))))
        (org-super-agenda-groups
         '((:discard
            (:deadline past
             :deadline future
             :scheduled future
             :scheduled past))
           (:auto-map cashpw/org-super-agenda--get-priority
            :transformer cashpw/org-super-agenda--simplify-map)
           (:discard (:anything)))))))))

