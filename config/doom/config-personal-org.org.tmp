(defun cashpw/org-agenda-view--today--files ()
  "Return a list of files containing tasks for today's agenda."
  (seq-uniq
   (append
    (cashpw/rgrep
     (format
      "-l :everyday: %s/*.org"
      cashpw/path--notes-dir))
    (cashpw/rgrep
     (format
      "-l \"(SCHEDULED|DEADLINE): <%s\" %s/*.org"
      (format-time-string "%F" (current-time))
      cashpw/path--notes-dir)))))

