#+begin_src emacs-lisp :tangle config-personal.el :results none
(defun cashpw/revert-file (filename)
  "Revert FILENAME."
  (when (file-exists-p filename)
    (with-current-buffer
        (find-file-noselect
         filename)
      (revert-buffer))))

(defun cashpw/revert-common-files ()
  "Revert common Org files and their archives."
  (interactive)
  (let* ((files
          `(,(cashpw/path-todos)
            ,(cashpw/path-calendar)))
         (files-with-archive
          (append
           files
           (org-extras-files-archive-files
            files))))
    (--each
        files-with-archive
      (cashpw/revert-file it))))
#+end_src

