(defun cashpw/kill-all-markdown-buffers ()
  "Kill all other org-roam buffers except current."
  (let ((buffers-to-kill
         (--filter (s-ends-with-p ".md" (buffer-name it)) (buffer-list))))
    (mapc 'kill-buffer buffers-to-kill)))
