#+begin_src emacs-lisp :tangle config-personal.el :results none
(defun cashpw/org-get-filetags (&optional file-path)
  "Return filetags in FILE-PATH."
  (when-let ((file-path (or file-path (buffer-file-name))))
    (let ((filetag-string
           (shell-command-to-string
            (concat
             (format "rg '^#\\+filetags:' %s" file-path)
             "| sed 's/.*#+filetags: \\(.*\\)/\\1/'"))))
      (s-split ":" filetag-string 'omit-nulls))))

(defun cashpw/org-files-and-filetags (directory)
  "Return list of org files in DIRECTORY and their filetags."
  (let ((grep-result
         ;; Outputs <filepath> <tags>
         ;; For example: /tmp/foo.org :cats:
         (shell-command-to-string
          (concat
           (format "rg --max-count=1 '^#\\+filetags:' %s/*.org"
                   (directory-file-name directory))
           " | sed 's/\\(.*\\):#+filetags: \\(.*\\)/\\1 \\2/'"))))
    (--map
     (cl-destructuring-bind
         (file filetags)
         (s-split " " it 'omit-nulls)
       (cons file (s-split ":" filetags 'omit-nulls)))
     (s-split "\n" grep-result 'omit-nulls))))

(defun cashpw/org-files-and-filetags-with-tag (tag directory)
  "Return list of org files tagged with TAG in DIRECTORY and their filetags.
Gracefully returns nil if no org files are found."
  ;; 1. Guard clause: Only execute if directory exists and contains .org files
  (when (and (file-directory-p directory)
             (directory-files directory nil "\\.org\\'"))
    (let ((grep-result
           ;; Outputs <filepath>\t<tags>
           ;; For example: /tmp/foo.org:cats:
           (shell-command-to-string
            (format "rg --max-count=1 --max-depth=1 -g '*.org' '^#\\+filetags:.*:%s:' %s | sed 's/\\(.*\\):#+filetags: \\(.*\\)/\\1\t\\2/'"
                    tag
                    ;; 2. Secure the directory path against shell injection and spaces
                    (shell-quote-argument (directory-file-name directory))))))
      (--map
       (cl-destructuring-bind
           (file filetags)
           ;; 3. Split by literal tab instead of space to handle filenames containing spaces
           (s-split "\t" it 'omit-nulls)
         (cons file (s-split ":" filetags 'omit-nulls)))
       (s-split "\n" grep-result 'omit-nulls)))))

(defun cashpw/org-files-with-tag (tag directory)
  "Return list of org files in DIRECTORY tagged (filetag) with TAG."
  (cashpw/org-files-with-tags (list tag) directory))

(defun cashpw/org-files-with-tags (tags directory)
  "Return list of org files in DIRECTORY tagged (filetag) with all TAGS."
  (--map
   (car it)
   (-filter
    (lambda (file-and-filetags)
      (-every (lambda (tag) (member tag (cdr file-and-filetags))) tags))
    (cashpw/org-files-and-filetags-with-tag (cl-first tags) directory))))

(defun cashpw/notes-files-with-tag (tag)
  "Return a list of note files containing TAG."
  (cashpw/org-files-with-tag tag cashpw/path--notes-dir))

(defun cashpw/notes-files-with-tags (&rest tags)
  "Return a list of note files tagged with all TAGS."
  (cashpw/org-files-with-tags tags cashpw/path--notes-dir))
#+end_src

****** Files by creation date

#+begin_src emacs-lisp :tangle config-personal.el :results none
(defun cashpw/org-files-by-creation-range (directory start end)
  "Return sorted list of .org files in DIRECTORY created between START and END.
Arguments START and END should be Emacs time objects. Creation date is
determined by the first \":CREATED:\" in the file."
  (let (paths-and-times)
    (with-temp-buffer
      (insert
       (shell-command-to-string
        (format
         "find %s -name \"*.org\" -exec grep -H -m 1 -Z \"^:CREATED:\" {} +"
         (shell-quote-argument (expand-file-name directory)))))
      (goto-char (point-min))
      ;; Regex: [Filename]\0:CREATED: [Timestamp]
      (while (re-search-forward
              "^\\([^\0]+\\)\0:CREATED:[ \t]*\\(\\[[^]]+\\]\\|<[^>]+>\\)"
              nil t)
        (let* ((file-path (match-string 1))
               (file-time
                (ignore-errors
                  (org-time-string-to-time
                   (match-string 2)))))
          (when (and file-time
                     (not (time-less-p file-time start))
                     (not (time-less-p end file-time)))
            ;; start <= file-time <= end
            (push (cons file-path file-time) paths-and-times)))))
    (-map #'car (sort paths-and-times #'(lambda (a b) (time-less-p (cdr a) (cdr b)))))))
#+end_src

#+begin_src elisp
(let ((start (date-to-time "2023-01-01"))
      (end   (date-to-time "2023-12-31")))
  (get-org-files-by-creation-range "~/proj/notes" start end))
#+end_src

